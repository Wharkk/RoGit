function Components.showConfirmDialog(parentWidget: DockWidgetPluginGui, config: {
	title: string,
	message: string,
	confirmText: string?,
	cancelText: string?,
	onConfirm: () -> (),
	onCancel: (() -> ())?,
	})
	-- Overlay covers entire widget
